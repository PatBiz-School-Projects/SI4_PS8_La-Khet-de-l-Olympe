{
  "appId": "com.pns.khet",
  "appName": "Khet de l'Olympe",
  "webDir": "./dist",
  "server": {
    "hostname": "khet-olympe.mobile.app",
    "androidScheme": "https"
  },
  "plugins": {
      "CapacitorCookies": {
          "enabled": true
      },
      "CapacitorHttp": {
          "enabled": true
      },
      "SplashScreen": {
          "launchShowDuration": 0,
          "launchAutoHide": true,
          "backgroundColor": "#121016",
          "splashFullScreen": true,
          "splashImmersive": true
      }
  }
}
